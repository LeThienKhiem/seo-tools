# Anthropic API key — lay tu https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Model dung cho audit (sonnet nhanh + re, opus chinh xac hon)
# Khuyen nghi: claude-sonnet-4-6 cho audit binh thuong
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: tang tokens cho audit lon
MAX_TOKENS=16000

# Project roots ma File Patcher duoc phep ghi vao.
# Comma-separated absolute paths. Lý do an toan: tranh ghi de nhầm vào folder khác.
PATCH_ALLOWED_ROOTS=/Users/lethienkhiem/Documents/CodeProject/pdf-converter
